SECRETS=$(kamal secrets fetch --adapter 1password --account <YOUR_1PASSWORD_ACCOUNT> --from "<YOUR_VAULT/ITEM>" KAMAL_REGISTRY_USERNAME KAMAL_REGISTRY_PASSWORD RAILS_MASTER_KEY)
KAMAL_REGISTRY_USERNAME=$(kamal secrets extract KAMAL_REGISTRY_USERNAME ${SECRETS})
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD ${SECRETS})
RAILS_MASTER_KEY=$(kamal secrets extract RAILS_MASTER_KEY ${SECRETS})
DEPLOY_HOST=$(kamal secrets extract DEPLOY_HOST ${SECRETS})

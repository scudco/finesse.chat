<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Finesse" %></title>

    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Finesse">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="A live chat demo built with Rails 8, Hotwire, and SolidCable — supporting WebSockets, SSE, and polling transports.">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Finesse">
    <meta property="og:url" content="https://REDACTED_DOMAIN/">
    <meta property="og:title" content="Finesse Chat — Real-time Rails 8 demo with WebSockets &amp; SSE">
    <meta property="og:description" content="A live chat demo built with Rails 8, Hotwire, and SolidCable — supporting WebSockets, SSE, and polling transports.">
    <meta property="og:image" content="https://REDACTED_DOMAIN/ogimage.jpg">
    <meta property="og:image:type" content="image/jpeg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Finesse Chat interface showing real-time messages">
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://REDACTED_DOMAIN/">
    <meta property="twitter:title" content="Finesse Chat — Real-time Rails 8 demo with WebSockets &amp; SSE">
    <meta property="twitter:description" content="A live chat demo built with Rails 8, Hotwire, and SolidCable — supporting WebSockets, SSE, and polling transports.">
    <meta property="twitter:image" content="https://REDACTED_DOMAIN/ogimage.jpg">
    <meta property="twitter:image:alt" content="Finesse Chat interface showing real-time messages">
    <meta name="theme-color" content="#0d9488">
    <meta name="current-user" content="<%= current_username %>">
    <script>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (t !== 'light' && matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png?v=2" type="image/png">
    <link rel="icon" href="/icon.svg?v=2" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png?v=2">
    <link rel="manifest" href="/manifest.json">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white dark:bg-gray-900 dark:text-gray-100">
    <nav class="fixed top-0 w-full h-14 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between px-6 z-10">
      <%= link_to "FC", root_path, class: "font-semibold text-gray-800 dark:text-gray-100 hover:text-teal-600 dark:hover:text-teal-400 transition-colors" %>
      <div class="flex items-center gap-3">
        <button data-controller="modal-trigger"
                data-action="click->modal-trigger#open"
                class="w-7 h-7 flex items-center justify-center rounded-md bg-teal-600 hover:bg-teal-500 cursor-pointer text-white font-bold text-sm transition-colors"
                title="Help & Reference">?</button>
        <button data-controller="theme" data-action="click->theme#cycle"
                class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer text-gray-700 dark:text-gray-300 opacity-0">
          <span data-theme-target="light"><%= heroicon "sun", variant: :outline, options: { class: "w-4 h-4" } %></span>
          <span data-theme-target="dark"><%= heroicon "moon", variant: :outline, options: { class: "w-4 h-4" } %></span>
        </button>
        <div class="flex items-center gap-1.5 text-sm bg-gray-100 dark:bg-gray-800 rounded-md pl-2.5 pr-0.5 py-0.5">
          <strong style="color: <%= author_color(current_username) %>"><%= current_username %></strong>
          <%= button_to session_path, method: :delete,
                form: { class: "inline" },
                class: "w-6 h-6 flex items-center justify-center rounded hover:bg-gray-200 dark:hover:bg-gray-700 cursor-pointer text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300",
                title: "New username" do %>
            <%= heroicon "arrow-path", variant: :outline, options: { class: "w-3.5 h-3.5" } %>
          <% end %>
        </div>
      </div>
    </nav>
    <main class="container mx-auto mt-20 sm:mt-14 px-2 sm:px-5 flex">
      <%= yield %>
    </main>
    <%= render "layouts/help_modal" %>
  </body>
</html>

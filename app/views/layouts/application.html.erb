<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Finesse Chat — A Fine SSE Microapp" %></title>

    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Finesse Chat">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="A chat microapp built with Rails 8, Hotwire, and SolidCable — compares Polling, WebSockets, and Server-Sent Events.">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Finesse Chat">
    <meta property="og:url" content="https://finesse.chat/">
    <meta property="og:title" content="Finesse Chat — A Fine SSE Microapp">
    <meta property="og:description" content="A chat microapp built with Rails 8, Hotwire, and SolidCable — compares Polling, WebSockets, and Server-Sent Events.">
    <meta property="og:image" content="<%= image_url('ogimage.png') %>">
    <meta property="og:image:type" content="image/png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Finesse Chat banner showing messages lines">
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://finesse.chat/">
    <meta property="twitter:title" content="Finesse Chat — A Fine SSE Microapp">
    <meta property="twitter:description" content="A chat microapp built with Rails 8, Hotwire, and SolidCable — compares Polling, WebSockets, and Server-Sent Events.">
    <meta property="twitter:image" content="<%= image_url('ogimage.png') %>">
    <meta property="twitter:image:alt" content="Finesse Chat banner showing messages lines">
    <meta name="theme-color" content="#0d9488">

    <script>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (t !== 'light' && matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="<%= image_url('icon.png') %>" type="image/png">
    <link rel="icon" href="<%= image_url('icon.png') %>" type="image/png" sizes="any">
    <link rel="apple-touch-icon" href="<%= image_url('icon.png') %>">
    <link rel="manifest" href="/manifest.json">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white dark:bg-gray-900 dark:text-gray-100">
    <nav class="fixed top-0 w-full h-14 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between px-6 z-10">
      <%= link_to root_path, class: "flex items-center gap-2 font-semibold text-gray-800 dark:text-gray-100 hover:text-teal-600 dark:hover:text-teal-400 transition-colors" do %>
        <%= image_tag 'icon.png', class: 'w-7 h-7 rounded-md', alt: 'Finesse Chat' %>
        <span class="hidden md:inline font-serif">Finesse Chat</span>
      <% end %>
      <div class="flex items-center gap-3">
        <a href="https://github.com/scudco/finesse.chat" target="_blank"
           class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-700 dark:text-gray-300"
           title="View source on GitHub">
          <svg class="w-4.5 h-4.5" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        </a>
        <button data-controller="modal-trigger"
                data-action="click->modal-trigger#open"
                class="w-7 h-7 flex items-center justify-center rounded-md bg-teal-600 hover:bg-teal-500 cursor-pointer text-white font-bold text-sm transition-colors"
                title="Help & Reference">?</button>
        <button data-controller="theme" data-action="click->theme#cycle"
                class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer text-gray-700 dark:text-gray-300 opacity-0">
          <span data-theme-target="light"><%= heroicon "sun", variant: :outline, options: { class: "w-4 h-4" } %></span>
          <span data-theme-target="dark"><%= heroicon "moon", variant: :outline, options: { class: "w-4 h-4" } %></span>
        </button>
        <div class="flex items-center gap-1.5 text-sm bg-gray-100 dark:bg-gray-800 rounded-md pl-2.5 pr-0.5 py-0.5">
          <strong id="current-username" style="color: <%= author_color(current_username) %>"><%= current_username %></strong>
          <%= button_to session_path, method: :patch,
                form: { class: "inline" },
                class: "w-6 h-6 flex items-center justify-center rounded hover:bg-gray-200 dark:hover:bg-gray-700 cursor-pointer text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300",
                title: "New username" do %>
            <%= heroicon "arrow-path", variant: :outline, options: { class: "w-3.5 h-3.5" } %>
          <% end %>
        </div>
      </div>
    </nav>
    <main class="container mx-auto mt-14 px-2 sm:px-5 flex">
      <%= yield %>
    </main>
    <%= render "layouts/help_modal" %>
  </body>
</html>

<%# locals: (message:) %>
<%= form_with(model: message, class: "pb-4") do |form| %>
  <% if message.errors.any? %>
    <p class="text-sm text-red-500 mb-2"><%= message.errors.full_messages.to_sentence %></p>
  <% end %>
  <div class="flex items-stretch gap-2">
    <%= form.text_area :content,
          placeholder: "Type a message…",
          rows: 1,
          class: "flex-1 field-sizing-content resize-none overflow-y-auto max-h-32 rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500",
          autofocus: true,
          required: true,
          maxlength: 2000,
          data: { action: "keydown->chat#submitOnEnter" } %>
    <%= form.submit "Send",
          class: "rounded-lg px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium cursor-pointer shrink-0" %>
  </div>
  <p class="hidden sm:block text-xs text-gray-400 mt-1" data-chat-target="hint"></p>
<% end %>

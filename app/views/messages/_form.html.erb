<%# locals: (message:) %>
<%= form_with(model: message, class: "flex flex-col gap-2 pb-4") do |form| %>
  <% if message.errors.any? %>
    <p class="text-sm text-red-500"><%= message.errors.full_messages.to_sentence %></p>
  <% end %>

  <%= form.hidden_field :author, value: current_username %>

  <div class="flex items-center gap-2">
    <%= form.text_field :content,
          placeholder: "Type a message…",
          class: "rounded-sm border border-gray-300 px-3 py-2 flex-1 focus:outline-none focus:ring-2 focus:ring-blue-500",
          autofocus: true,
          required: true %>
    <%= form.submit "Send",
          class: "rounded-sm px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer shrink-0" %>
  </div>
<% end %>

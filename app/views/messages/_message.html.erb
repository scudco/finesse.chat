<%# locals: (message:, current_user: nil) %>

<div
    id="<%= dom_id message %>"
    class="flex flex-col px-2 py-1 hover:bg-gray-200"
    >
  <div class="flex items-baseline justify-between gap-1">
    <span class="font-semibold text-sm truncate"
          style="color: <%= author_color(message.author) %>"
          ><%= message.author.presence %></span>
    <time
        class="text-xs text-gray-400 shrink-0"
        datetime="<%= message.created_at.iso8601 %>"
        data-controller="local-time"><%= message.created_at.strftime("%H:%M") %></time>
  </div>
  <div class="text-gray-800 max-w-0 min-w-full [overflow-wrap:anywhere]">
    <%= message.content %>
  </div>
</div>

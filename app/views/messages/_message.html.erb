<%# locals: (message:, current_user: nil) %>
<%# own_message: render controls when current_user is unknown (broadcast) or is the author %>
<% own_message = current_user.nil? || message.author == current_user %>

<div
    id="<%= dom_id message %>"
    class="group flex flex-col px-2 py-1 hover:bg-gray-200 dark:hover:bg-gray-700"
    data-controller="message"
    data-message-author-value="<%= message.author %>"
    >
  <div class="flex items-baseline justify-between gap-1">
    <span class="font-semibold text-sm truncate"
          style="color: <%= author_color(message.author) %>"
          ><%= message.author.presence %></span>
    <div class="flex items-center gap-2">
      <% if own_message %>
        <div class="hidden group-hover:flex items-center gap-2" data-message-target="actions">
          <button data-action="click->message#startEdit"
                  class="text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 cursor-pointer">Edit</button>
          <%= link_to "Delete", message_path(message),
                data: { turbo_method: :delete },
                class: "text-xs text-gray-400 hover:text-red-500 cursor-pointer" %>
        </div>
      <% end %>
      <time
          class="text-xs text-gray-400 shrink-0"
          datetime="<%= message.created_at.iso8601 %>"
          data-controller="local-time"><%= message.created_at.strftime("%H:%M") %></time>
    </div>
  </div>
  <div class="text-gray-800 dark:text-gray-100 max-w-0 min-w-full [overflow-wrap:anywhere] chat-content"
       <% if own_message %>data-message-target="content"<% end %>>
    <%= render_chat_markdown(message.content) %>
  </div>
  <% if own_message %>
    <div class="hidden" data-message-target="editor">
      <%= form_with model: message, data: { action: "submit->message#submitted" } do |f| %>
        <%= f.text_area :content,
              class: "w-full text-sm text-gray-800 dark:text-gray-100 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded px-2 py-1 resize-none focus:outline-none focus:ring-1 focus:ring-blue-500",
              rows: 3,
              data: { action: "keydown->message#keydown", message_target: "textarea" } %>
        <div class="flex gap-3 mt-1 text-xs">
          <button type="submit" class="text-blue-600 dark:text-blue-400 hover:text-blue-500 dark:hover:text-blue-300 cursor-pointer font-medium">Save</button>
          <button type="button" data-action="click->message#cancelEdit"
                  class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 cursor-pointer">Cancel</button>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
<div id="<%= dom_id message %>" class="flex flex-col" data-author="<%= message.author %>">
  <div class="flex items-baseline justify-between gap-2 mb-1">
    <span class="message-author font-semibold text-sm truncate"
          title="<%= message.author.presence || "Anonymous" %>"><%= message.author.presence || "Anonymous" %></span>
    <span class="message-time text-xs text-gray-400 shrink-0"><%= message.created_at.strftime("%H:%M") %></span>
  </div>
  <div class="message-bubble bg-white border rounded-xl px-4 py-2 max-w-prose text-gray-800">
    <%= message.content %>
  </div>
</div>

<% content_for :title, "Chat" %>

<div class="flex flex-col h-[calc(100dvh-3.5rem)] w-full max-w-2xl mx-auto px-4"
     data-controller="chat"
     data-chat-older-url-value="<%= older_messages_path %>"
     data-chat-newer-url-value="<%= newer_messages_path %>"
     data-chat-poll-interval-value="7777">
  <% if @transport == "sse" %>
    <turbo-stream-source src="<%= sse_stream_url("chat") %>"></turbo-stream-source>
  <% elsif @transport == "ws" %>
    <%= turbo_stream_from "chat" %>
  <% end %>

  <div class="shrink-0 pt-4 pb-2 space-y-1.5">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold">Finesse Chat</h1>
      <div class="flex text-xs font-medium rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700">
        <% [["none", "Polling"], ["ws", "WS"], ["sse", "SSE"]].each do |value, label| %>
          <% if @transport == value && value == "none" %>
            <%= link_to messages_path(transport: value),
                  class: "px-3 py-1.5 relative overflow-hidden bg-blue-700 text-white" do %>
              <span class="absolute inset-0 bg-blue-600 origin-left" data-chat-target="pollBar"></span>
              <span class="relative"><%= label %></span>
            <% end %>
          <% else %>
            <% active_class = { "sse" => "bg-teal-600 text-white", "ws" => "bg-amber-500 text-white" }[value] || "bg-blue-600 text-white" %>
            <%= link_to label, messages_path(transport: value),
                  class: "px-3 py-1.5 #{@transport == value ? active_class : "bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700"}" %>
          <% end %>
        <% end %>
      </div>
    </div>
    <div class="flex items-center justify-between">
      <div data-controller="countdown">
        <p class="text-xs text-gray-400">Chat resets in <span data-countdown-target="label"></span></p>
        <div class="mt-1 h-px w-48 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
          <div class="h-full bg-gray-400 dark:bg-gray-500 transition-[width] duration-1000 ease-linear" data-countdown-target="bar"></div>
        </div>
      </div>
      <%= button_to bot_storm_messages_path,
            class: "rounded-lg px-3 py-1.5 bg-red-500 hover:bg-red-400 text-white text-xs font-medium cursor-pointer flex items-center gap-1",
            data: { turbo_submits_with: "Bot Storm" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" class="shrink-0"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Bot Storm
      <% end %>
    </div>
  </div>

  <div class="flex-1 overflow-y-auto overflow-x-hidden border border-gray-200 dark:border-gray-700 rounded-sm bg-gray-50 dark:bg-gray-800 mb-4 opacity-0 transition-opacity duration-600"
       data-chat-target="scroll"
       data-action="scroll->chat#onScroll">
    <div class="text-center text-xs text-gray-400 pt-3 pb-1 hidden" data-chat-target="loadOlder">
      Loading older messages…
    </div>
    <div id="messages" class="flex flex-col justify-end min-h-full space-y-1" data-chat-target="messages">
      <%= render "messages_list", messages: @messages, current_user: current_username %>
    </div>
    <div data-chat-target="jumpButton" class="sticky bottom-4 flex justify-center hidden">
      <button data-action="click->chat#jumpToPresent"
              class="bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-full shadow-lg cursor-pointer">
        ↓ Jump to present
      </button>
    </div>
  </div>

  <%= turbo_frame_tag "message_form" do %>
    <%= render "form", message: Message.new %>
  <% end %>
</div>

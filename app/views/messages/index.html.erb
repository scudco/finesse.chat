<% content_for :title, "Chat" %>

<div class="flex flex-col h-[calc(100vh-3.5rem)] max-w-2xl mx-auto px-4"
     data-controller="chat"
     data-chat-current-user-value="<%= current_username %>">
  <turbo-stream-source src="<%= sse_stream_url("chat") %>"></turbo-stream-source>

  <h1 class="text-2xl font-bold py-4 shrink-0">Finesse Chat</h1>

  <div class="flex-1 overflow-y-auto border rounded-xl bg-gray-50 mb-4" data-chat-target="scroll">
    <div id="messages" class="flex flex-col justify-end min-h-full space-y-4 p-4">
      <%= render @messages %>
    </div>
  </div>

  <%= turbo_frame_tag "message_form" do %>
    <%= render "form", message: Message.new %>
  <% end %>
</div>

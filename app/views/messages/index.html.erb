<% content_for :title, "Chat" %>

<div class="flex flex-col h-[calc(100dvh-3.5rem)] w-full max-w-2xl mx-auto px-4"
     data-controller="chat"
     data-chat-older-url-value="<%= older_messages_path %>"
     data-chat-newer-url-value="<%= newer_messages_path %>"
     data-chat-poll-interval-value="7777"
     data-chat-transport-value="<%= @transport %>">
  <% if @transport == "sse" %>
    <turbo-stream-source src="<%= sse_stream_url("chat") %>"></turbo-stream-source>
  <% elsif @transport == "ws" %>
    <%= turbo_stream_from "chat" %>
  <% end %>

  <div class="shrink-0 pt-4 pb-2 space-y-1.5">
    <div class="flex items-center justify-between gap-3">
      <h1 class="text-2xl font-bold font-mono break-all"><span id="channel_name"><%= @channel_name %></span></h1>
      <div class="relative shrink-0" data-controller="countdown" data-action="click->countdown#toggleTooltip touchstart->countdown#toggleTooltip">
        <svg width="20" height="20" viewBox="0 0 20 20" class="rotate-[-90deg] opacity-0 transition-opacity duration-300" data-countdown-target="svg">
          <circle cx="10" cy="10" r="8" fill="none" stroke="currentColor" stroke-width="2" class="text-gray-200 dark:text-gray-700"/>
          <circle cx="10" cy="10" r="8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-teal-500 dark:text-teal-400" data-countdown-target="ring"/>
        </svg>
        <div class="absolute bottom-full right-0 mb-1.5 px-2 py-1 text-xs bg-gray-800 dark:bg-gray-700 text-white rounded whitespace-nowrap pointer-events-none opacity-0 transition-opacity duration-150 z-50" data-countdown-target="tooltip">
          resets in <span data-countdown-target="label"></span>
        </div>
      </div>
    </div>
    <div class="flex items-center justify-between">
      <% tooltips = { "none" => "Fetch latest messages every 7.77s", "ws" => "Stream via WebSockets", "sse" => "Stream via Server-Sent Events" } %>
      <% transports = [["none", "Polling"], ["ws", "WS"], ["sse", "SSE"]] %>
      <div class="flex text-xs font-medium rounded-lg border border-gray-200 dark:border-gray-700">
        <% transports.each_with_index do |(value, label), i| %>
          <% first_item = i == 0; last_item = i == transports.size - 1 %>
          <% round = first_item ? "rounded-l-lg" : last_item ? "rounded-r-lg" : "" %>
          <% divider = last_item ? "" : "border-r border-gray-200 dark:border-gray-700" %>
          <div class="relative group <%= divider %>">
            <% if @transport == value && value == "none" %>
              <%= link_to root_path(transport: value),
                    class: "block px-3 py-1.5 relative overflow-hidden bg-blue-700 text-white #{round}" do %>
                <span class="absolute inset-0 bg-blue-600 origin-left" data-chat-target="pollBar"></span>
                <span class="relative"><%= label %></span>
              <% end %>
            <% else %>
              <% active_class = { "sse" => "bg-teal-600 text-white", "ws" => "bg-amber-500 text-white" }[value] || "bg-blue-600 text-white" %>
              <%= link_to label, root_path(transport: value),
                    data: (@transport == value ? { chat_target: "transportButton" } : {}),
                    class: "block px-3 py-1.5 #{round} #{@transport == value ? active_class : "bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700"}" %>
            <% end %>
            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2 py-1 text-xs bg-gray-800 dark:bg-gray-700 text-white rounded whitespace-nowrap pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-150 z-50">
              <%= tooltips[value] %>
            </div>
          </div>
        <% end %>
      </div>
      <%= button_to bot_storm_messages_path,
            data: { controller: "cooldown", action: "click->cooldown#start", cooldown_duration_value: 5000 },
            form: { class: "contents" },
            class: "btn-storm" do %>
        <span class="btn-storm-bar origin-left" data-cooldown-target="bar"></span>
        <span class="relative flex items-center gap-1">
          <span class="bolt-zap"><%= heroicon "bolt", variant: :solid, options: { class: "w-3.5 h-3.5 shrink-0" } %></span>
          Bot Storm
        </span>
      <% end %>
    </div>

  </div>

  <div class="flex-1 overflow-y-auto overflow-x-hidden border border-gray-200 dark:border-gray-700 rounded-sm bg-gray-50 dark:bg-gray-800 mb-4 opacity-0 transition-opacity duration-600"
       data-chat-target="scroll"
       data-action="scroll->chat#onScroll">
    <div class="text-center text-xs text-gray-400 pt-3 pb-1 hidden" data-chat-target="loadOlder">
      Loading older messages…
    </div>
    <div id="messages" class="flex flex-col justify-end min-h-full space-y-1" data-chat-target="messages">
      <%= render "messages_list", messages: @messages, current_user: current_username %>
    </div>
    <div data-chat-target="jumpButton" class="sticky bottom-4 flex justify-center hidden">
      <button data-action="click->chat#jumpToPresent"
              class="bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-full shadow-lg cursor-pointer">
        ↓ Jump to present
      </button>
    </div>
  </div>

  <%= turbo_frame_tag "message_form" do %>
    <%= render "form", message: Message.new %>
  <% end %>
</div>
